# TopicForge runtime configuration.
# Copy to `.env` and edit; or export these variables directly.

# Runtime mode: mock | live | auto
#   mock — always use deterministic fixtures (default for development & CI)
#   live — require ROS2 CLI; never fall back
#   auto — use live if `ros2` is on PATH, otherwise mock
TOPICFORGE_MODE=auto

# Log level: DEBUG | INFO | WARNING | ERROR
TOPICFORGE_LOG_LEVEL=INFO

# Override the ROS2 executable name (rarely needed).
TOPICFORGE_ROS2_BIN=ros2

# Opt-in anonymous usage telemetry: on | off (default: off).
# When on, each tool call emits {tool_name, latency_ms, mode, version,
# session_id, success}. session_id is a random UUID regenerated on every
# server start — never persisted. No topic names, no message bodies, no
# bag paths, no environment data — see the README "Telemetry" section.
TOPICFORGE_TELEMETRY=off

# DDS module backend: mock | cyclone | fast | rti | auto (default: mock).
#   mock    — deterministic fixtures, no SDK required (default)
#   cyclone — Eclipse CycloneDDS, requires `pip install topicforge[dds-cyclone]`
#   fast    — eProsima Fast DDS, requires `pip install topicforge[dds-fast]`
#   rti     — RTI Connext (Pro tier, v0.4.0+ roadmap, BYO license)
#   auto    — pick best available: Fast > Cyclone > Mock
# Both Cyclone and Fast are OMG DDS-RTPS conformant ; they observe every
# vendor on the bus — see docs/dds-interop-matrix.md for the canonical
# multi-vendor positioning and the OMG May 2025 interop reference.
TOPICFORGE_DDS_BACKEND=mock

# DDS domain id observed when the DDS module is active (0..232).
TOPICFORGE_DDS_DOMAIN_ID=0
